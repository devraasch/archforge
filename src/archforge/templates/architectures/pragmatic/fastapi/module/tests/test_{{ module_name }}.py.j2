"""Tests for {{ module_name }} module."""

from uuid import UUID

from fastapi.testclient import TestClient

from {{ package_name }}.main import app

client = TestClient(app)


def test_list_{{ module_name }}_empty():
    response = client.get("/{{ module_name }}/")
    assert response.status_code == 200
    assert response.json() == []


{% if options.crud %}
def test_create_and_get_{{ module_name }}():
    create_response = client.post(
        "/{{ module_name }}/",
        json={"name": "Sample"},
    )
    assert create_response.status_code == 201
    payload = create_response.json()
    item_id = payload["id"]

    get_response = client.get(f"/{{ module_name }}/{item_id}")
    assert get_response.status_code == 200
    assert get_response.json()["name"] == "Sample"


def test_get_{{ module_name }}_not_found():
    response = client.get(f"/{{ module_name }}/{UUID(int=0)}")
    assert response.status_code == 404
{% endif %}
