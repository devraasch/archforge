[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ project_name }} — generated by archforge"
readme = "README.md"
requires-python = ">={{ python_version }}"
dependencies = [
    "django>=5.1",
    "pydantic>=2.10",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
    "pytest-django>=4.9",
    "ruff>=0.8",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.pytest.ini_options]
DJANGO_SETTINGS_MODULE = "{{ package_name }}.settings"
testpaths = ["tests", "src"]
pythonpath = ["src"]

[tool.ruff]
target-version = "py312"
line-length = 100
src = ["src", "tests"]

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "SIM"]
